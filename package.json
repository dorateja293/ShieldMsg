{
  "name": "sentinelchat",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered secure social media and real-time messaging platform with automatic threat detection.",
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:frontend": "npm run dev --workspace sentinelchat-frontend",
    "dev:backend": "npm run dev --workspace sentinelchat-backend",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "start": "npm run start --workspace sentinelchat-backend"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
