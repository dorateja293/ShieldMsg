{
  "name": "shieldmsg",
  "version": "0.1.0",
  "private": true,
  "description": "Secure messaging prototype with real-time link and file threat indicators.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:web": "npm run dev --workspace @shieldmsg/web",
    "dev:api": "npm run build --workspace @shieldmsg/threat-engine && npm run dev --workspace @shieldmsg/api",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3"
  }
}
