NODE_ENV=development
PORT=5000

# Browser origins allowed for CORS + Socket.IO (comma-separated, no spaces).
# Local only:
CLIENT_URL=http://localhost:5173
# Local + Vercel production (typical when you develop against a deployed API):
# CLIENT_URL=http://localhost:5173,https://your-app.vercel.app
# Vercel Preview deployments use a different URL each time — add them here or test only on Production.

# MongoDB Atlas or local. This repo reads MONGODB_URI (not MONGO_URI).
MONGODB_URI=mongodb://127.0.0.1:27017/sentinelchat

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
MAX_FILE_SIZE_MB=25

# Render: set the same keys in the dashboard. Render injects PORT — do not hardcode it there.
