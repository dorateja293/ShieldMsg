# Local development
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# Vercel: Project → Settings → Environment Variables (Production + Preview), then redeploy.
# VITE_API_URL: Render HTTPS URL — may be https://your-app.onrender.com OR .../api (both work).
# VITE_SOCKET_URL: same host without /api (optional if VITE_API_URL is set).
# VITE_API_URL=https://your-backend.onrender.com/api
# VITE_SOCKET_URL=https://your-backend.onrender.com
